{
  "name": "dapume-js",
  "version": "0.3.0",
  "description": "打谱么 —— 将线性乐谱（dapume）解析为乐谱对象并渲染为 MIDI 文件。可在 Node 与浏览器环境运行。",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "dapume",
    "linear-score",
    "midi",
    "music",
    "notation",
    "simple-score",
    "jianpu"
  ],
  "author": "AkagiYui",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AkagiYui/dapume-js.git",
    "directory": "dapume-js"
  },
  "homepage": "https://github.com/AkagiYui/dapume-js#readme",
  "bugs": {
    "url": "https://github.com/AkagiYui/dapume-js/issues"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
